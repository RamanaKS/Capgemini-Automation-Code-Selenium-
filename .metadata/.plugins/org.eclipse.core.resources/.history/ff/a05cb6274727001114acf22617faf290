package com.orangehrm.seleniumuiframework.object_repository;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.support.FindBy;
import org.openqa.selenium.support.PageFactory;
import com.orangehrm.seleniumuiframework.genericutility.ActionUtility;

public class AddEmployeePage {

    ActionUtility actUtil;

    public AddEmployeePage(WebDriver driver) {
        PageFactory.initElements(driver, this);
        actUtil = new ActionUtility(driver);
    }

    @FindBy(name = "firstName")
    private WebElement firstName;

    @FindBy(name = "middleName")
    private WebElement middleName;

    @FindBy(name = "lastName")
    private WebElement lastName;

    @FindBy(xpath = "//label[text()='Employee Id']/../following-sibling::div/input")
    private WebElement employeeId;

    @FindBy(css = ".oxd-switch-input.oxd-switch-input--active.--label-right")
    private WebElement loginToggle;

    @FindBy(xpath = "(//input[@class='oxd-input oxd-input--active'])[3]")
    private WebElement userName;

    @FindBy(xpath = "(//input[@type='password'])[1]")
    private WebElement password;

    @FindBy(xpath = "(//input[@type='password'])[2]")
    private WebElement confirmPassword;

    @FindBy(xpath = "//button[.=' Save ']")
    private WebElement saveBtn;

    public void setFirstName(String fname) {
        actUtil.sendKeys(firstName, fname);
    }

    public void setMiddleName(String mname) {
        actUtil.sendKeys(middleName, mname);
    }

    public void setLastName(String lname) {
        actUtil.sendKeys(lastName, lname);
    }

    public void setEmployeeId(String id) {
        actUtil.clearAndType(employeeId, id);
    }

    public void clickLoginToggle() {
        actUtil.click(loginToggle);
    }

    public void setUserName(String uname) {
        actUtil.sendKeys(userName, uname);
    }

    public void setPassword(String pwd) {
        actUtil.sendKeys(password, pwd);
    }

    public void setConfirmPassword(String pwd) {
        actUtil.sendKeys(confirmPassword, pwd);
    }

    public void clickSaveBtn() {
        actUtil.click(saveBtn);
    }

    public void addEmployee(String fname, String mname, String lname, String id) {

        setFirstName(fname);
        setMiddleName(mname);
        setLastName(lname);
        setEmployeeId(id);
        clickLoginToggle();
    }

    public void createCredentials(String uname, String pwd) {
        setUserName(uname);
        setPassword(pwd);
        setConfirmPassword(pwd);
        clickSaveBtn();
    }
}