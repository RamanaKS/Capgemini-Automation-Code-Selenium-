package Demo;

import java.io.FileInputStream;
import java.io.FileOutputStream;
import java.io.IOException;
import java.util.Properties;

import org.testng.annotations.Test;

import com.orangehrm.seleniumuiframework.genericutility.BaseClass1;

public class practice extends BaseClass1 {

	@Test
	public void readData() throws IOException {

		String path = "./src/main/resources/orangehrm.CommonData/CommonData.properties";

		Properties prop = new Properties();

		FileInputStream fis = new FileInputStream(path);
		prop.load(fis);
		fis.close();
		prop.setProperty("browser", "edge");
		FileOutputStream fos = new FileOutputStream(path);
		prop.store(fos, "Updated Data");
		fos.close();
		System.out.println("Property updated successfully");
	}
}